---
import { Icon } from 'astro-icon/components';
import type { PetAgeUI } from './index';
import './style.css';

interface Props {
  ui: PetAgeUI;
}

const { ui } = Astro.props;
---

<!-- Share overlay -->
<div id="share-overlay" class="age-share-overlay">
  <div class="age-share-wrap">
    <div class="age-share-card">
      <div class="age-share-card-header">
        <div class="age-share-badge">{ui.humanAgeTitle}</div>
        <div class="age-share-animal">
          <div id="share-icon-dog" class="hidden"><Icon name="mdi:dog-side" /></div>
          <div id="share-icon-cat" class="hidden"><Icon name="mdi:cat" /></div>
        </div>
        <h1 id="share-pet-name"></h1>
      </div>
      <div class="age-share-card-body">
        <p class="age-share-human-label">{ui.humanAgeLabel}</p>
        <span id="share-human-age">--</span>
        <p class="age-share-years-label">{ui.humanAgeYears}</p>
        <div class="age-share-info-grid">
          <div class="age-share-info-item">
            <span class="age-share-info-label">{ui.realAgeLabel}</span>
            <div>
              <span id="share-chronological-age" class="age-share-info-val">--</span>
              <span class="age-share-info-val"> {ui.humanAgeYears}</span>
            </div>
          </div>
          <div class="age-share-info-item">
            <span class="age-share-info-label">{ui.lifeStageLabel}</span>
            <span id="share-life-stage" class="age-share-info-val"></span>
          </div>
        </div>
      </div>
      <div class="age-share-card-footer" id="share-domain"></div>
    </div>
    <button id="create-new-btn" class="age-share-new-btn">
      <Icon name="mdi:refresh" />
      <span>{ui.recalculateBtn}</span>
    </button>
  </div>
</div>

<!-- Calculator -->
<div id="calculator-container" class="pet-age-calculator" data-ui={JSON.stringify(ui)}>
  <div class="age-loader" id="ageLoader">
    <Icon name="mdi:loading" class="age-loader-spinner" />
  </div>

  <div class="age-container">

    <!-- Perfil -->
    <div class="age-section">
      <h3 class="age-section-title">
        <Icon name="mdi:paw" /> {ui.toolTitle}
      </h3>

      <div class="age-input-item">
        <label class="age-label" for="pet-name">{ui.petNameLabel}</label>
        <input
          type="text"
          id="pet-name"
          placeholder={ui.petNamePlaceholder}
          class="age-text-input"
          autocomplete="off"
        />
      </div>

      <div class="age-input-item">
        <label class="age-label">Animal</label>
        <div class="age-species-selector">
          <button class="pet-type-btn active" data-type="dog">
            <Icon name="mdi:dog-side" class="age-icon" /> {ui.petTypeDog}
          </button>
          <button class="pet-type-btn" data-type="cat">
            <Icon name="mdi:cat" class="age-icon" /> {ui.petTypeCat}
          </button>
        </div>
      </div>

      <div class="age-input-item" id="dog-size-selector">
        <label class="age-label">Tamaño</label>
        <div class="age-segmented">
          <button class="size-btn active" data-size="small">{ui.sizeSmall}</button>
          <button class="size-btn" data-size="medium">{ui.sizeMedium}</button>
          <button class="size-btn" data-size="large">{ui.sizeLarge}</button>
          <button class="size-btn" data-size="giant">{ui.sizeGiant}</button>
        </div>
      </div>
    </div>

    <!-- Año de nacimiento -->
    <div class="age-section">
      <h3 class="age-section-title">
        <Icon name="mdi:calendar" /> {ui.birthYearLabel}
      </h3>
      <div class="age-year-wrap">
        <input
          type="number"
          id="birth-year-input"
          placeholder="2021"
          class="age-year-input"
        />
      </div>
    </div>

    <!-- Resultado -->
    <div class="age-results">
      <div class="age-res-main">
        <span class="age-res-label">
          {ui.humanAgeLabel} <span id="result-pet-name" class="hidden"></span>
        </span>
        <div class="age-res-number">
          <span id="human-age">--</span>
          <small>{ui.humanAgeYears}</small>
        </div>
      </div>
      <div class="age-res-divider"></div>
      <div class="age-res-grid">
        <div class="age-res-card">
          <span class="age-res-card-label">{ui.lifeStageLabel}</span>
          <span id="life-stage" class="age-res-card-val">---</span>
        </div>
        <div class="age-res-card">
          <span class="age-res-card-label">{ui.milestoneLabel}</span>
          <span id="next-milestone" class="age-res-card-val">---</span>
        </div>
      </div>
      <div class="age-res-footer">
        <button id="share-btn" class="age-share-btn">
          <Icon name="mdi:share-variant" class="age-icon-sm" />
          <span id="share-text">{ui.shareBtn}</span>
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  import {
    calculatePetHumanAge,
    getDogStageKey,
    getCatStageKey,
    getDogMilestone,
    getCatMilestone,
  } from './logic';
  import type { PetSpecies, DogSize } from './logic';

  function initPetAge() {
    const shareOverlay = document.getElementById('share-overlay');
    const calculatorContainer = document.getElementById('calculator-container');
    const sharePetName = document.getElementById('share-pet-name');
    const shareHumanAge = document.getElementById('share-human-age');
    const shareChronologicalAge = document.getElementById('share-chronological-age');
    const shareLifeStage = document.getElementById('share-life-stage');
    const shareIconDog = document.getElementById('share-icon-dog');
    const shareIconCat = document.getElementById('share-icon-cat');
    const createNewBtn = document.getElementById('create-new-btn');
    const petBtns = document.querySelectorAll<HTMLElement>('.pet-type-btn');
    const sizeBtns = document.querySelectorAll<HTMLElement>('.size-btn');
    const dogSizeSelector = document.getElementById('dog-size-selector');
    const birthYearInput = document.getElementById('birth-year-input') as HTMLInputElement;
    const humanAgeDisplay = document.getElementById('human-age');
    const lifeStageDisplay = document.getElementById('life-stage');
    const nextMilestoneDisplay = document.getElementById('next-milestone');
    const petNameInput = document.getElementById('pet-name') as HTMLInputElement;
    const resultPetNameSpan = document.getElementById('result-pet-name');
    const shareBtn = document.getElementById('share-btn');
    const shareText = document.getElementById('share-text');
    const loader = document.getElementById('ageLoader');

    if (!birthYearInput) return;

    const uiData: Record<string, string> = JSON.parse(calculatorContainer?.dataset.ui || '{}');

    const shareDomain = document.getElementById('share-domain');
    if (shareDomain) shareDomain.textContent = window.location.hostname;

    let petType: PetSpecies = 'dog';
    let dogSize: DogSize = 'small';
    let birthYear: number | null = null;
    let petName = '';

    const currentYear = new Date().getFullYear();
    birthYearInput.max = currentYear.toString();

    function getLifeStage(humanAge: number): string {
      const key = petType === 'cat' ? getCatStageKey(humanAge) : getDogStageKey(humanAge);
      return uiData[key] || key;
    }

    function getMilestone(chronologicalAge: number): string {
      return petType === 'cat' ? getCatMilestone(chronologicalAge) : getDogMilestone(chronologicalAge);
    }

    function updateNameDisplay() {
      if (!resultPetNameSpan) return;
      if (petName.trim() !== '') {
        resultPetNameSpan.classList.remove('hidden');
        resultPetNameSpan.textContent = petName;
      } else {
        resultPetNameSpan.classList.add('hidden');
      }
    }

    function update() {
      if (!birthYear) {
        if (humanAgeDisplay) humanAgeDisplay.textContent = '--';
        if (lifeStageDisplay) lifeStageDisplay.textContent = '---';
        if (nextMilestoneDisplay) nextMilestoneDisplay.textContent = '---';
        updateNameDisplay();
        return;
      }
      const chronologicalAge = currentYear - birthYear;
      const humanAge = calculatePetHumanAge(petType, chronologicalAge, dogSize);
      if (humanAgeDisplay) humanAgeDisplay.textContent = humanAge.toString();
      if (lifeStageDisplay) lifeStageDisplay.textContent = getLifeStage(humanAge);
      if (nextMilestoneDisplay) nextMilestoneDisplay.textContent = getMilestone(chronologicalAge);
      updateNameDisplay();
    }

    function renderShareCard() {
      if (!birthYear) return;
      const chronologicalAge = currentYear - birthYear;
      const humanAge = calculatePetHumanAge(petType, chronologicalAge, dogSize);
      if (sharePetName) sharePetName.textContent = petName;
      if (shareHumanAge) shareHumanAge.textContent = humanAge.toString();
      if (shareChronologicalAge) shareChronologicalAge.textContent = chronologicalAge.toString();
      if (shareLifeStage) shareLifeStage.textContent = getLifeStage(humanAge);
      if (shareIconDog && shareIconCat) {
        shareIconDog.classList.toggle('hidden', petType !== 'dog');
        shareIconCat.classList.toggle('hidden', petType !== 'cat');
      }
    }

    const params = new URLSearchParams(window.location.search);
    if (params.has('birthYear') && params.has('type')) {
      if (shareOverlay) shareOverlay.classList.add('visible');
      if (calculatorContainer) calculatorContainer.style.display = 'none';
      petName = params.get('name') || uiData.defaultPetName || '';
      petType = (params.get('type') || 'dog') as PetSpecies;
      dogSize = (params.get('size') || 'medium') as DogSize;
      birthYear = parseInt(params.get('birthYear') || '0');
      renderShareCard();
    } else {
      if (shareOverlay) shareOverlay.classList.remove('visible');
      if (calculatorContainer) calculatorContainer.style.display = 'block';
    }

    createNewBtn?.addEventListener('click', () => {
      window.location.href = window.location.origin + window.location.pathname;
    });

    petNameInput?.addEventListener('input', (e) => {
      petName = (e.target as HTMLInputElement).value;
      update();
    });

    petBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        petType = (target.dataset.type || 'dog') as PetSpecies;
        petBtns.forEach((b) => b.classList.remove('active'));
        target.classList.add('active');
        if (dogSizeSelector) dogSizeSelector.style.display = petType === 'dog' ? 'block' : 'none';
        update();
      });
    });

    sizeBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        dogSize = ((e.currentTarget as HTMLElement).dataset.size || 'small') as DogSize;
        sizeBtns.forEach((b) => b.classList.remove('active'));
        (e.currentTarget as HTMLElement).classList.add('active');
        update();
      });
    });

    birthYearInput.addEventListener('input', (e) => {
      const val = parseInt((e.target as HTMLInputElement).value);
      if (!isNaN(val) && val > 1900 && val <= currentYear) {
        birthYear = val;
        birthYearInput.classList.remove('age-input--error');
        birthYearInput.classList.add('age-input--valid');
      } else {
        birthYear = null;
        if (birthYearInput.value.length === 4) {
          birthYearInput.classList.add('age-input--error');
          birthYearInput.classList.remove('age-input--valid');
        } else {
          birthYearInput.classList.remove('age-input--valid', 'age-input--error');
        }
      }
      update();
    });

    shareBtn?.addEventListener('click', async () => {
      if (!birthYear) {
        birthYearInput.focus();
        birthYearInput.classList.add('age-input--error');
        setTimeout(() => birthYearInput.classList.remove('age-input--error'), 500);
        return;
      }
      const sp = new URLSearchParams();
      if (petName) sp.set('name', petName);
      sp.set('type', petType);
      if (petType === 'dog') sp.set('size', dogSize);
      sp.set('birthYear', birthYear.toString());
      const newUrl = `${window.location.origin}${window.location.pathname}?${sp.toString()}`;
      try {
        await navigator.clipboard.writeText(newUrl);
        if (shareText) shareText.textContent = '¡Copiado!';
        if (shareBtn) shareBtn.classList.add('age-btn-success');
        setTimeout(() => { window.location.href = newUrl; }, 800);
      } catch {
        window.location.href = newUrl;
      }
    });

    update();
    setTimeout(() => { if (loader) loader.classList.add('hidden'); }, 50);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPetAge);
  } else {
    initPetAge();
  }
  document.addEventListener('astro:page-load', initPetAge);
</script>
