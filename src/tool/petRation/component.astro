---
import { Icon } from 'astro-icon/components';
import type { PetRationUI } from './index';

interface Props {
  ui: PetRationUI;
}

const { ui } = Astro.props;
---

<div class="pet-ration-calculator-final" id="calcWrapper" data-ui={JSON.stringify(ui)}>
  <div class="calc-loader" id="calcLoader">
    <Icon name="mdi:loading" class="loader-spinner" />
  </div>

  <div class="calc-container">
    <div class="calc-section">
      <h3 class="section-title">{ui.sectionProfile}</h3>

      <div class="input-item">
        <label class="item-label">{ui.labelAnimal}</label>
        <div class="species-selector-v2">
          <input type="radio" name="petType" id="pet-dog" value="dog" checked />
          <label for="pet-dog" class="btn-species">
            <Icon name="mdi:dog" class="icon-v2" /> {ui.speciesDog}
          </label>
          <input type="radio" name="petType" id="pet-cat" value="cat" />
          <label for="pet-cat" class="btn-species">
            <Icon name="mdi:cat" class="icon-v2" /> {ui.speciesCat}
          </label>
          <input type="radio" name="petType" id="pet-rabbit" value="rabbit" />
          <label for="pet-rabbit" class="btn-species">
            <Icon name="mdi:rabbit" class="icon-v2" /> {ui.speciesRabbit}
          </label>
        </div>
      </div>

      <div class="input-item">
        <label class="item-label">{ui.labelStage}</label>
        <div class="segmented-v2">
          <input type="radio" name="lifeStage" id="stage-puppy" value="puppy" />
          <label for="stage-puppy">{ui.stagePuppy}</label>
          <input type="radio" name="lifeStage" id="stage-adult" value="adult" checked />
          <label for="stage-adult">{ui.stageAdult}</label>
          <input type="radio" name="lifeStage" id="stage-senior" value="senior" />
          <label for="stage-senior">{ui.stageSenior}</label>
        </div>
      </div>

      <div class="input-item">
        <div class="label-row-v2">
          <label class="item-label">{ui.labelWeight}</label>
          <div class="val-badge"><span id="weightDisplay">10</span> kg</div>
        </div>
        <input type="range" id="weightRange" min="1" max="85" step="0.5" value="10" class="range-v2" />
      </div>

      <div class="input-item">
        <label class="item-label">{ui.labelActivity}</label>
        <div class="segmented-v2 activity-box">
          <input type="radio" name="activity" id="act-low" value="low" />
          <label for="act-low">{ui.activityLow}</label>
          <input type="radio" name="activity" id="act-mod" value="mod" checked />
          <label for="act-mod">{ui.activityMod}</label>
          <input type="radio" name="activity" id="act-high" value="high" />
          <label for="act-high">{ui.activityHigh}</label>
        </div>
      </div>
    </div>

    <div class="calc-section">
      <h3 class="section-title">{ui.sectionDiet}</h3>

      <div class="input-item">
        <label class="item-label">{ui.labelDietType}</label>
        <div class="ratio-presets">
          <input type="radio" name="dietRatioPreset" id="r-dry" value="0" checked />
          <label for="r-dry">{ui.dietDry}</label>
          <input type="radio" name="dietRatioPreset" id="r-mixed" value="25" />
          <label for="r-mixed">{ui.dietMixed25}</label>
          <input type="radio" name="dietRatioPreset" id="r-half" value="50" />
          <label for="r-half">{ui.dietHalf}</label>
          <input type="radio" name="dietRatioPreset" id="r-wet" value="100" />
          <label for="r-wet">{ui.dietWet}</label>
        </div>
        <div class="custom-ratio-link" id="showManualSlider">{ui.manualAdjust}</div>
        <div class="manual-slider-box" id="manualSliderBox" style="display: none;">
          <input type="range" id="dietRatioRange" min="0" max="100" step="5" value="0" class="range-v2 ratio-slider" />
          <div class="ratio-labels">
            <span>{ui.wetPercentLabel}</span>
            <strong id="ratioValDisplay">0%</strong>
          </div>
        </div>
      </div>
    </div>

    <div class="results-v2">
      <div class="res-cards-v2">
        <div class="res-card-v2 dry" id="dryResCard">
          <span class="res-tag">{ui.tagDry}</span>
          <span class="res-num"><span id="dryResVal">0</span><small>g</small></span>
        </div>
        <div class="res-card-v2 wet" id="wetResCard" style="display: none;">
          <span class="res-tag">{ui.tagWet}</span>
          <span class="res-num"><span id="wetResVal">0</span><small>g</small></span>
        </div>
      </div>
      <div class="res-footer-v2">
        <div class="total-info">
          <Icon name="mdi:chart-donut" class="footer-icon" />
          {ui.totalKcal}: <strong id="kcalTotalVal">0</strong> {ui.kcalUnit}
        </div>
        <div class="status-box-v2" id="statusBoxV2">{ui.statusDefault}</div>
      </div>
    </div>
  </div>
</div>

<script>
  import { getFormState, setRadioValue, setMaxWeightRange, getStoredConfig, applyPresetLogic, updateDisplay } from "./handlers";

  function setupRationListeners(calculate: () => void, weightRange: HTMLInputElement, ratioRange: HTMLInputElement) {
    document.getElementById("calcWrapper")?.addEventListener("input", calculate);
    document.getElementById("calcWrapper")?.addEventListener("change", calculate);

    const manualBox = document.getElementById("manualSliderBox");
    const showManual = document.getElementById("showManualSlider");
    showManual?.addEventListener("click", () => {
      if (manualBox) manualBox.style.display = "block";
      if (showManual) showManual.style.display = "none";
    });

    const presets = document.getElementsByName("dietRatioPreset") as NodeListOf<HTMLInputElement>;
    presets.forEach((preset) => {
      preset.addEventListener("change", () => {
        ratioRange.value = preset.value;
        calculate();
      });
    });

    document.getElementsByName("petType").forEach((radio) => {
      radio.addEventListener("change", () => {
        setMaxWeightRange((radio as HTMLInputElement).value);
        calculate();
      });
    });
  }

  function initPetRation() {
    const wrapper = document.getElementById("calcWrapper");
    const weightRange = document.getElementById("weightRange") as HTMLInputElement;
    const ratioRange = document.getElementById("dietRatioRange") as HTMLInputElement;
    if (!wrapper || !weightRange || !ratioRange) return;

    const uiData = JSON.parse(wrapper.dataset.ui || "{}");
    const config = getStoredConfig();

    setRadioValue("petType", config.s);
    setRadioValue("lifeStage", config.st);
    setRadioValue("activity", config.a);
    weightRange.value = config.w;
    ratioRange.value = config.r;
    setMaxWeightRange(config.s);
    applyPresetLogic(config.r);

    const calculate = () => updateDisplay(getFormState(), uiData);
    setupRationListeners(calculate, weightRange, ratioRange);

    calculate();
    document.getElementById("calcLoader")?.classList.add("hidden");
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPetRation);
  } else {
    initPetRation();
  }
  document.addEventListener("astro:page-load", initPetRation);
</script>

<style>
.pet-ration-calculator-final {
    position: relative;
    max-width: 650px;
    margin: 2rem auto;
    background: var(--color-surface, #fff);
    border-radius: 2rem;
    padding: 2.5rem;
    box-shadow: 0 20px 50px -15px rgba(0, 0, 0, 0.08);
    color: var(--color-text, #334155);
    border: 1px solid var(--color-border, #f1f5f9);
    min-height: 400px;
}

.calc-loader {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-surface, #fff);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 2rem;
    z-index: 50;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1), visibility 0.4s;
}

:global(.theme-dark) .pet-ration-calculator-final {
    background: var(--color-surface-dark, #1e293b);
    color: var(--color-text-dark, #e2e8f0);
    border-color: var(--color-border-dark, #334155);
    box-shadow: 0 20px 50px -15px rgba(0, 0, 0, 0.3);
}

:global(.theme-dark) .calc-loader {
    background: var(--color-surface-dark, #1e293b);
}

.calc-loader.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.loader-spinner {
    width: 3rem;
    height: 3rem;
    color: var(--color-accent, #f59e0b);
    animation: spin-pulse 2s infinite linear;
}

@keyframes spin-pulse {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.calc-container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    animation: fade-in-up 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fade-in-up {
    from {
        opacity: 0;
        transform: translateY(10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.section-title {
    font-size: 1.1rem;
    font-weight: 950;
    color: var(--color-heading, #0f172a);
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

:global(.theme-dark) .section-title {
    color: var(--color-heading-dark, #f8fafc);
}

.calc-section {
    border-bottom: 1px dashed var(--color-border-dashed, #e2e8f0);
    padding-bottom: 2rem;
}

.calc-section:last-of-type {
    border-bottom: none;
}

:global(.theme-dark) .calc-section {
    border-bottom-color: var(--color-border-dark, #334155);
}

.input-item {
    margin-bottom: 2rem;
}

.item-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-label, #94a3b8);
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
}

.species-selector-v2 {
    display: flex;
    gap: 1rem;
}

.species-selector-v2 input {
    display: none;
}

.btn-species {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem 0.75rem;
    background: var(--color-btn-bg, #f8fafc);
    border: 2px solid var(--color-btn-border, #e2e8f0);
    border-radius: 1rem;
    cursor: pointer;
    font-weight: 800;
    font-size: 1rem;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

:global(.theme-dark) .btn-species {
    background: var(--color-btn-bg-dark, #0f172a);
    border-color: var(--color-btn-border-dark, #334155);
}

.icon-v2 {
    width: 1.5rem;
    height: 1.5rem;
}

.species-selector-v2 input:checked + .btn-species {
    background: var(--color-surface, #fff);
    border-color: var(--color-accent, #f59e0b);
    color: var(--color-accent, #f59e0b);
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.15);
    transform: translateY(-2px);
}

:global(.theme-dark) .species-selector-v2 input:checked + .btn-species {
    background: var(--color-surface-elevated-dark, #1e293b);
}

.segmented-v2 {
    display: flex;
    background: var(--color-btn-bg, #f8fafc);
    padding: 6px;
    border-radius: 1rem;
    border: 1px solid var(--color-btn-border, #e2e8f0);
}

:global(.theme-dark) .segmented-v2 {
    background: var(--color-btn-bg-dark, #0f172a);
    border-color: var(--color-btn-border-dark, #334155);
}

.segmented-v2 input {
    display: none;
}

.segmented-v2 label {
    flex: 1;
    text-align: center;
    padding: 0.85rem;
    border-radius: 0.75rem;
    cursor: pointer;
    font-weight: 700;
    font-size: 0.85rem;
    transition: all 0.2s;
    color: var(--color-muted, #64748b);
}

.segmented-v2 input:checked + label {
    background: var(--color-accent, #f59e0b);
    color: var(--color-on-accent, #fff);
    box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
}

.val-badge {
    font-weight: 950;
    color: var(--color-accent, #f59e0b);
    font-size: 1.25rem;
}

.label-row-v2 {
    display: flex;
    justify-content: space-between;
}

.range-v2 {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 8px;
    background: var(--color-range-track, #e2e8f0);
    border-radius: 10px;
}

:global(.theme-dark) .range-v2 {
    background: var(--color-range-track-dark, #334155);
}

.range-v2::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 26px;
    height: 26px;
    background: var(--color-surface, #fff);
    border: 6px solid var(--color-accent, #f59e0b);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
}

.ratio-presets {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
}

.ratio-presets input {
    display: none;
}

.ratio-presets label {
    padding: 0.85rem;
    text-align: center;
    background: var(--color-btn-bg, #f8fafc);
    border: 1px solid var(--color-btn-border, #e2e8f0);
    border-radius: 0.75rem;
    cursor: pointer;
    font-weight: 700;
    font-size: 0.85rem;
    transition: all 0.2s;
}

:global(.theme-dark) .ratio-presets label {
    background: var(--color-btn-bg-dark, #0f172a);
    border-color: var(--color-btn-border-dark, #334155);
}

.ratio-presets input:checked + label {
    background: var(--color-surface, #fff);
    border-color: var(--color-accent, #f59e0b);
    color: var(--color-accent, #f59e0b);
    box-shadow: 0 4px 10px rgba(245, 158, 11, 0.1);
}

:global(.theme-dark) .ratio-presets input:checked + label {
    background: var(--color-surface-elevated-dark, #1e293b);
}

.custom-ratio-link {
    display: block;
    text-align: right;
    font-size: 0.75rem;
    color: var(--color-label, #94a3b8);
    margin-top: 1rem;
    cursor: pointer;
    text-decoration: underline;
}

.manual-slider-box {
    margin-top: 2rem;
    padding: 1.5rem;
    background: var(--color-btn-bg, #f8fafc);
    border-radius: 1rem;
    border: 1px solid var(--color-btn-border, #e2e8f0);
}

:global(.theme-dark) .manual-slider-box {
    background: var(--color-btn-bg-dark, #0f172a);
    border-color: var(--color-btn-border-dark, #334155);
}

.ratio-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    margin-top: 1rem;
    font-weight: 700;
}

.results-v2 {
    background: var(--color-results-bg, #0f172a);
    border-radius: 2rem;
    padding: 2.5rem;
    color: var(--color-results-text, #fff);
    box-shadow: 0 20px 40px -10px rgba(15, 23, 42, 0.3);
}

:global(.theme-dark) .results-v2 {
    background: var(--color-accent, #f59e0b);
    color: var(--color-results-text-dark, #0f172a);
    box-shadow: 0 20px 40px -10px rgba(245, 158, 11, 0.2);
}

.res-cards-v2 {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.res-card-v2 {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-left: 4px solid var(--color-accent, #f59e0b);
    padding: 0.5rem 1.5rem;
}

:global(.theme-dark) .res-card-v2 {
    border-left-color: var(--color-results-bg, #0f172a);
}

.res-tag {
    font-size: 0.8rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--color-accent, #f59e0b);
    margin-bottom: 0.25rem;
    align-self: flex-start;
}

:global(.theme-dark) .res-tag {
    color: var(--color-results-bg, #0f172a);
    opacity: 0.7;
}

.res-num {
    font-size: 4rem;
    font-weight: 950;
    line-height: 1;
    align-self: flex-start;
}

.res-num small {
    font-size: 1.25rem;
    margin-left: 4px;
    opacity: 0.6;
}

.res-footer-v2 {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

:global(.theme-dark) .res-footer-v2 {
    border-top-color: rgba(0, 0, 0, 0.1);
}

.total-info {
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.total-info strong {
    font-size: 1.4rem;
}

.footer-icon {
    width: 1.5rem;
    height: 1.5rem;
}

.status-box-v2 {
    background: var(--color-accent, #f59e0b);
    color: var(--color-on-accent, #fff);
    padding: 0.4rem 1.25rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 900;
}

:global(.theme-dark) .status-box-v2 {
    background: var(--color-results-bg, #0f172a);
    color: var(--color-results-text, #fff);
}

@media (max-width: 600px) {
    .pet-ration-calculator-final {
        padding: 1.5rem;
        margin: 1rem;
    }

    .species-selector-v2 {
        flex-direction: column;
    }

    .res-cards-v2 {
        flex-direction: column;
    }

    .res-footer-v2 {
        flex-direction: column;
        gap: 1.5rem;
        text-align: center;
    }
}
</style>
